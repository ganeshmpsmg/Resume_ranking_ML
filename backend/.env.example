# ──────────────────────────────────────────────
# Resume Ranking System — Backend Environment
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────

# App
APP_ENV=development
DEBUG=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_pass
POSTGRES_DB=resume_ranking

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL_SECONDS=3600

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma

# Sentence-BERT model (auto-downloaded on first use)
SBERT_MODEL_NAME=all-MiniLM-L6-v2

# Hybrid search weights (must sum to 1.0)
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_BM25_WEIGHT=0.3

# Ranking weights (must sum to 1.0)
WEIGHT_SEMANTIC_SIMILARITY=0.40
WEIGHT_SKILL_MATCH=0.25
WEIGHT_EXPERIENCE_MATCH=0.20
WEIGHT_EDUCATION_MATCH=0.10
WEIGHT_PROJECT_RELEVANCE=0.05

# OpenAI (optional — only needed for /feedback/llm bonus endpoint)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.5-mini

# File upload
MAX_UPLOAD_MB=10
